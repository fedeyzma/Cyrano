# --- Hermes / OpenAI-compatible LLM endpoint ---
# Point this at your self-hosted Hermes agent (or any OpenAI-compatible server:
# llama.cpp server, vLLM, LM Studio, Ollama's /v1, etc.)
LLM_BASE_URL=http://localhost:1234/v1
# Many local servers ignore the key, but the SDK requires a non-empty value.
LLM_API_KEY=not-needed
# The model id your server exposes (e.g. hermes-4, gpt-5.5, etc.)
LLM_MODEL=hermes-4

# --- Storage ---
# Path to the SQLite database file. In Docker this is mounted as a volume.
DATABASE_PATH=./data/cyrano.db

# --- Generation tuning (optional) ---
# How many reply options to generate per request (2-5).
SUGGESTION_COUNT=4
# Sampling temperature for the reply generator.
LLM_TEMPERATURE=0.9
# Hard timeout for an LLM request, in milliseconds.
LLM_TIMEOUT_MS=60000
