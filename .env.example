# --- Cami (Hermes) OpenAI-compatible endpoint ---
# Cami is reached server-side only; the key never touches the browser.
CAMI_API_URL=http://192.168.69.244:8642
CAMI_API_KEY=replace-with-secret
CAMI_API_MODEL=cami
CAMI_API_TIMEOUT_MS=45000

# --- Generation tuning (optional) ---
# How many reply options to generate per request (2-5).
SUGGESTION_COUNT=4
# Sampling temperature for the reply generator.
SUGGESTION_TEMPERATURE=0.8

# --- Storage ---
# Path to the SQLite database file. In Docker this is mounted as a volume.
DATABASE_PATH=./data/cyrano.db
